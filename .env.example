# =============================================================================
# .env.example — AI Text Humanizer
# Copy this file to .env.local for local development with `vercel dev`.
# Add each key to your Vercel project dashboard under:
#   Settings → Environment Variables
# NEVER commit .env.local or any file containing real secrets to Git.
# =============================================================================

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get this from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get both values from: Supabase Dashboard → Project Settings → API

# Your project's REST API base URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# The SERVICE ROLE key (not the anon/public key).
# This key has admin access and bypasses Row Level Security.
# It must ONLY ever be used server-side (i.e., inside /api/* functions).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Lock this down to your production frontend domain in production.
# Leave as * during local development.
# Example: https://humane.vercel.app
ALLOWED_ORIGIN=*
